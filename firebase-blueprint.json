{
  "entities": {
    "lista_coleta": {
      "title": "ListaColeta",
      "description": "Item planejado de coleta operacional (Bolsão D+1) - Legacy",
      "type": "object",
      "properties": {
        "lista": {
          "type": "string"
        },
        "loja": {
          "type": "string"
        },
        "setor": {
          "type": "integer"
        },
        "corte": {
          "type": "string"
        },
        "carregamento": {
          "type": "string"
        },
        "transportadora": {
          "type": "string"
        },
        "volumes": {
          "type": "integer"
        },
        "enderecos": {
          "type": "integer"
        },
        "atividadeRelacionada": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        }
      },
      "required": ["lista", "loja", "setor", "corte", "carregamento"]
    },
    "radar_lojas_status": {
      "title": "RadarLojasStatus",
      "description": "Status operacional e timeline de rastreio de cada lista - Legacy",
      "type": "object",
      "properties": {
        "lista": {
          "type": "string"
        },
        "statusSoltura": {
          "type": "string",
          "enum": ["Não Solta", "Solta"]
        },
        "horarioSoltura": {
          "type": "string"
        },
        "soltoPor": {
          "type": "string"
        },
        "statusColeta": {
          "type": "string",
          "enum": ["Não iniciada", "Em andamento", "Coletada"]
        },
        "horarioColeta": {
          "type": "string"
        },
        "coletadoPor": {
          "type": "string"
        },
        "statusCarregamento": {
          "type": "string",
          "enum": ["Não carregada", "Em andamento", "Carregada"]
        },
        "horarioCarregamento": {
          "type": "string"
        },
        "carregadoPor": {
          "type": "string"
        },
        "statusExpedicao": {
          "type": "string",
          "enum": ["Pendente", "Dentro do horário", "Dentro da tolerância", "Fora do horário"]
        },
        "updated_at": {
          "type": "string"
        },
        "updated_by": {
          "type": "string"
        }
      },
      "required": ["lista", "statusSoltura", "statusColeta", "statusCarregamento", "statusExpedicao", "updated_at", "updated_by"]
    },
    "store_master": {
      "title": "StoreMaster",
      "description": "Cadastro mestre de lojas (sem dependência de setor ou data)",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "nome": {
          "type": "string"
        },
        "cidade": {
          "type": "string"
        },
        "uf": {
          "type": "string"
        },
        "transportadoraPadrao": {
          "type": "string"
        },
        "observacoes": {
          "type": "string"
        }
      },
      "required": ["id", "nome", "cidade", "uf", "transportadoraPadrao"]
    },
