          "type": "string"
        },
        "setor": {
          "type": "string"
        },
        "transportadora": {
          "type": "string"
        },
        "corte": {
          "type": "string"
        },
        "carregamento": {
          "type": "string"
        },
        "volumes": {
          "type": "integer"
        },
        "enderecos": {
          "type": "integer"
