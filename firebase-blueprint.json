        "perdeuCorte": {
          "type": "boolean"
        },
        "updated_at": {
          "type": "string"
        },
        "updated_by": {
          "type": "string"
        }
      },
      "required": ["id", "programacaoId", "lojaId", "nomeLoja", "setor", "statusSoltura", "statusColeta", "statusCarregamento", "statusExpedicao", "updated_at", "updated_by"]
