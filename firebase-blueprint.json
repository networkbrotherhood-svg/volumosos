        "statusSoltura": {
          "type": "string",
          "enum": ["Não Solta", "Solta"]
        },
        "horarioSoltura": {
          "type": "string"
        },
        "soltoPor": {
          "type": "string"
        },
        "statusColeta": {
          "type": "string",
          "enum": ["Não iniciada", "Em andamento", "Coletada"]
