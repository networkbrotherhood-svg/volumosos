  "firestore": {
    "lista_coleta/{listaId}": {
      "schema": "lista_coleta",
      "description": "Legacy list item"
    },
    "radar_lojas_status/{listaId}": {
      "schema": "radar_lojas_status",
      "description": "Legacy list status"
    },
    "store_master/{storeId}": {
      "schema": "store_master",
      "description": "Cadastro mestre de lojas"
    },
    "store_operations/{opId}": {
      "schema": "store_operations",
      "description": "Operações diárias por loja e setor"
    },
    "atividade_loja/{ativId}": {
